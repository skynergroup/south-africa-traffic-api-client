# i-traffic API Configuration
# Copy this file to .env and add your actual API key

# Your i-traffic.co.za API key
I_TRAFFIC_API_KEY=your_api_key_here

# API Base URL (usually doesn't need to change)
I_TRAFFIC_BASE_URL=https://www.i-traffic.co.za/api

# Default response format (json or xml)
I_TRAFFIC_DEFAULT_FORMAT=json

# Request timeout in milliseconds
I_TRAFFIC_TIMEOUT=10000

# Enable debug logging (true/false)
I_TRAFFIC_DEBUG=false
